Package: NWQS
Title: Non-Linear Weighted Quantile Sum Regression
Version: 0.1.0
Author: Zhehao Wang [aut, cre], Shirui Chen [aut], Ziqiang Lin [aut]
Maintainer: Zhehao Wang <wangzhehao_bill@foxmail.com>
Authors@R:
    c(person("Zhehao", "Wang", , "wangzhehao_bill@foxmail.com", role = c("aut", "cre")),
